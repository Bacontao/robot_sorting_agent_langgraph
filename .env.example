APP_ENV=dev
LOG_LEVEL=INFO
ARTIFACT_DIR=./artifacts

SEGMENTATION_BACKEND=auto
SEGMENTATION_ENDPOINT=
SEGMENTATION_FALLBACK_CHAIN=grounded_sam,yolo
SEGMENTATION_MIN_CANDIDATES=1
SEGMENTATION_MIN_CONFIDENCE=0.20
SEGMENTATION_FALLBACK_AFTER_FAILURES=2
SEGMENTATION_ALLOW_STUB_FALLBACK=false
YOLO_MODEL_PATH=yolo11n-seg.pt
YOLO_CONFIDENCE=0.25
YOLO_IMAGE_SIZE=640
YOLO_DEVICE=

# Preferred open-vocabulary segmentation: GroundingDINO + SAM vit_b, with YOLO fallback in auto mode.
GROUNDING_DINO_CONFIG=.models/GroundingDINO_SwinT_OGC.py
GROUNDING_DINO_CHECKPOINT=.models/groundingdino_swint_ogc.pth
GROUNDING_DINO_BOX_THRESHOLD=0.30
GROUNDING_DINO_TEXT_THRESHOLD=0.25
GROUNDING_TEXT_PROMPT=
SAM_CHECKPOINT=.models/sam_vit_b_01ec64.pth
SAM_MODEL_TYPE=vit_b
SAM_DEVICE=

LLM_BACKEND=heuristic
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=gpt-4.1-mini
OPENAI_COMPAT_RESPONSE_FORMAT=json_schema

# Optional role-specific OpenAI-compatible endpoints.
# Example: serve Qwen2.5-VL locally with vLLM for VLM, while planner/critic use another endpoint.
VLM_OPENAI_COMPAT_BASE_URL=
VLM_OPENAI_COMPAT_API_KEY=
VLM_OPENAI_COMPAT_RESPONSE_FORMAT=
PLANNER_OPENAI_COMPAT_BASE_URL=
PLANNER_OPENAI_COMPAT_API_KEY=
PLANNER_OPENAI_COMPAT_RESPONSE_FORMAT=
CRITIC_OPENAI_COMPAT_BASE_URL=
CRITIC_OPENAI_COMPAT_API_KEY=
CRITIC_OPENAI_COMPAT_RESPONSE_FORMAT=
TOOL_POLICY_OPENAI_COMPAT_BASE_URL=
TOOL_POLICY_OPENAI_COMPAT_API_KEY=
TOOL_POLICY_OPENAI_COMPAT_RESPONSE_FORMAT=
REPLAN_OPENAI_COMPAT_BASE_URL=
REPLAN_OPENAI_COMPAT_API_KEY=
REPLAN_OPENAI_COMPAT_RESPONSE_FORMAT=

VLM_MODEL=qwen2.5-vl-7b-instruct
PLANNER_MODEL=gpt-4.1-mini
CRITIC_MODEL=gpt-4.1-mini
TOOL_POLICY_MODEL=gpt-4.1-mini
REPLAN_MODEL=gpt-4.1-mini

INSPECT_THRESHOLD=0.55
TASK_RELEVANCE_THRESHOLD=0.40
ENABLE_TOOL_POLICY=true
ENABLE_EXECUTION_FEEDBACK_LOOP=true
MAX_REPLANS=2

# SiliconFlow profile example:
# SEGMENTATION_BACKEND=yolo
# YOLO_MODEL_PATH=yolo11n-seg.pt
# LLM_BACKEND=openai_compatible
# OPENAI_COMPAT_BASE_URL=https://api.siliconflow.cn/v1
# OPENAI_COMPAT_API_KEY=sk-your-siliconflow-api-key
# OPENAI_COMPAT_MODEL=Qwen/Qwen2.5-14B-Instruct
# OPENAI_COMPAT_RESPONSE_FORMAT=json_object
# VLM_MODEL=Qwen/Qwen3-VL-8B-Instruct
# VLM_OPENAI_COMPAT_RESPONSE_FORMAT=text
# PLANNER_MODEL=Qwen/Qwen2.5-14B-Instruct
# CRITIC_MODEL=Qwen/Qwen2.5-14B-Instruct
# TOOL_POLICY_MODEL=Qwen/Qwen2.5-14B-Instruct
# REPLAN_MODEL=Qwen/Qwen2.5-14B-Instruct
